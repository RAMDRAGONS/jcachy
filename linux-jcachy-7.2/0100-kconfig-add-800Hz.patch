From 0cfe618127353aa762c348fb94595343185de9dc Mon Sep 17 00:00:00 2001
From: Judas Drekonym <77771385+RAMDRAGONS@users.noreply.github.com>
Date: Wed, 8 Jul 2026 01:17:36 -0400
Subject: [PATCH] Apply 0100-kconfig-add-800Hz.patch

---
 kernel/Kconfig.hz | 18 ++++++++++++++++++
 1 file changed, 18 insertions(+)

diff --git a/kernel/Kconfig.hz b/kernel/Kconfig.hz
index e1359db556..40bb0724fd 100644
--- a/kernel/Kconfig.hz
+++ b/kernel/Kconfig.hz
@@ -54,6 +54,14 @@ choice
 	 on desktops with good smoothness without increasing CPU power
 	 consumption and sacrificing the battery life on laptops.
 
+	config HZ_625
+		bool "625 HZ"
+	help
+	 This Hz value is from the ECHO CPU scheduler project.
+	 625 Hz is a balanced timer frequency. Provides fast interactivity
+	 on desktops with good smoothness without increasing CPU power
+	 consumption and sacrificing the battery life on laptops.
+
 	config HZ_750
 		bool "750 HZ"
 	help
@@ -61,6 +69,14 @@ choice
 	 on desktops with good smoothness without increasing CPU power
 	 consumption and sacrificing the battery life on laptops.
 
+	config HZ_800
+		bool "800 HZ"
+	help
+	 Inspired by the ECHO Hz, the CachyMod author searched for another
+	 Hz value with four or less decimal places. (1 / 800Hz * 2 = 0.0025)
+	 800 Hz is an alternative to 1000 Hz. Choose 800 Hz if you want a
+	 balance between latency and performance, with more focus on latency.
+
 	config HZ_1000
 		bool "1000 HZ"
 	help
@@ -76,7 +92,9 @@ config HZ
 	default 300 if HZ_300
 	default 500 if HZ_500
 	default 600 if HZ_600
+	default 625 if HZ_625
 	default 750 if HZ_750
+	default 800 if HZ_800
 	default 1000 if HZ_1000
 
 config SCHED_HRTICK
-- 
2.55.0

